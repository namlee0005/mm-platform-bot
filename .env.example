# Exchange API credentials (REQUIRED)
EXCHANGE_API_KEY=your_mexc_api_key_here
EXCHANGE_API_SECRET=your_mexc_api_secret_here
EXCHANGE_BASE_URL=https://api.mexc.com

# Redis configuration
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# MongoDB configuration
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=bot_engine
MONGO_COLLECTION=fills

# HTTP server
HTTP_PORT=8080

# Logging
LOG_LEVEL=info